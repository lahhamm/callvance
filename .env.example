# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Create a local database named "callvance" and
# use the URL format below. On macOS with default Postgres settings the
# username is your system username and no password is required.
DATABASE_URL=postgresql://YOUR_USERNAME@localhost:5432/callvance

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Secret used to sign admin session tokens. Generate a random string:
#   node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
SESSION_SECRET=change_this_to_a_long_random_string

# Password to log in to the admin dashboard (default: nexus2024)
ADMIN_PASSWORD=nexus2024

# ─── Callvance Agents ─────────────────────────────────────────────────────────
# Separate product namespaced under /api/agents. This password logs into the
# Agents admin dashboard. Tenant portals log in with each tenant's own
# portalPassword (the "Apex Plumbing" demo tenant uses "apexdemo").
# The Agents admin token is HMAC-signed with the shared SESSION_SECRET above.
AGENTS_ADMIN_PASSWORD=agents2024

# ─── AI services ──────────────────────────────────────────────────────────────
# Anthropic API key — used for call summaries, lead scoring, and booking extraction
ANTHROPIC_API_KEY=sk-ant-api03-...

# Bland AI API key — used to initiate outbound voice calls
BLAND_AI_API_KEY=org_...

# ─── Webhooks ─────────────────────────────────────────────────────────────────
# Public URL of this API server that Bland AI can reach to send call webhooks.
# Leave blank to disable webhooks — the built-in poller will sync calls every
# 30 seconds instead (good enough for development).
#
# For local dev with webhooks: use ngrok or similar:
#   ngrok http 3001
# Then set SERVER_URL to the printed HTTPS URL, e.g.:
#   SERVER_URL=https://abc123.ngrok.io
SERVER_URL=

# ─── Booking notifications ───────────────────────────────────────────────────
# Email notifications via Resend (https://resend.com)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# SMS notifications via Twilio (https://twilio.com)
# Get credentials from: https://console.twilio.com
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# ─── Ports (optional — defaults shown) ───────────────────────────────────────
# API server port
PORT=3001

# Frontend dev server port (only needed if you want a non-default port)
# PORT=5173  ← this is the Vite default and is set per-process, not shared
